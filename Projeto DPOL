        errorQuestion.classList.add('hidden'); // Hide error
    }

    async function generateDiscursiveQuestion(disciplineName) {
        showModal();
        modalTitle.textContent = `Questão Discursiva de ${disciplineName}`;
        generatedQuestion.textContent = '';
        loadingIndicator.classList.remove('hidden');
        errorQuestion.classList.add('hidden');

        let chatHistory = [];
        const prompt = `Gerar uma questão discursiva de concurso público para a disciplina de ${disciplineName}, com foco em um tópico relevante para o cargo de Delegado da Polícia Federal. A questão deve ser desafiadora e exigir conhecimento aprofundado.`;
        chatHistory.push({ role: "user", parts: [{ text: prompt }] });

        const payload = { contents: chatHistory };
        const apiKey = ""; // Canvas will provide this at runtime
        const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${apiKey}`;

        try {
            const response = await fetch(apiUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await response.json();

            if (result.candidates && result.candidates.length > 0 &&
                result.candidates[0].content && result.candidates[0].content.parts &&
                result.candidates[0].content.parts.length > 0) {
                const text = result.candidates[0].content.parts[0].text;
                generatedQuestion.textContent = text;
            } else {
                generatedQuestion.textContent = '';
                errorQuestion.classList.remove('hidden');
                console.error("Erro: Estrutura de resposta inesperada ou conteúdo ausente.", result);
            }
        } catch (error) {
            generatedQuestion.textContent = '';
            errorQuestion.classList.remove('hidden');
            console.error("Erro ao chamar a Gemini API:", error);
        } finally {
            loadingIndicator.classList.add('hidden');
        }
    }


    document.addEventListener('DOMContentLoaded', function () {
        // Chart
        const ctx = document.getElementById('distribuicaoTempoChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Direito Administrativo', 'Direito Penal', 'Direito Processual Penal', 'Direito Constitucional'],
                datasets: [{
                    label: 'Distribuição de Horas Semanais',
                    data: [8, 8, 6, 6], // Horas
                    backgroundColor: [
                        'rgba(79, 70, 229, 0.7)',  // indigo-600
                        'rgba(99, 102, 241, 0.7)', // indigo-500
                        'rgba(129, 140, 248, 0.7)',// indigo-400
                        'rgba(165, 180, 252, 0.7)' // indigo-300
                    ],
                    borderColor: [
                        'rgba(79, 70, 229, 1)',
                        'rgba(99, 102, 241, 1)',
                        'rgba(129, 140, 248, 1)',
                        'rgba(165, 180, 252, 1)'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let label = context.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                if (context.parsed !== null) {
                                    label += context.parsed + 'h (aprox. ' + ((context.parsed / 28) * 100).toFixed(1) + '%)';
                                }
                                return label;
                            }
                        }
                    }
                }
            }
        });

        // Cronograma Tabs
        const tabsContainer = document.getElementById('tabs-container');
        const cronogramaContent = document.getElementById('cronograma-content');

        cronogramaData.forEach((semanaData, index) => {
            const button = document.createElement('button');
            button.className = 'tab-button px-4 py-2 text-sm sm:text-base font-medium rounded-md bg-slate-200 hover:bg-indigo-500 hover:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-opacity-50';
            button.textContent = `Semana ${semanaData.semana}` + (semanaData.semana === 9 ? " (Final)" : ` (${semanaData.periodo})`);
            button.onclick = () => loadSemanaContent(semanaData, button);
            tabsContainer.appendChild(button);
            if (index === 0) { // Load first week by default
                // loadSemanaContent(semanaData, button); // Defer to avoid issues on fast load
            }
        });
        
        // Set first tab as active after a slight delay to ensure DOM is ready
        setTimeout(() => {
            if (tabsContainer.children.length > 0) {
                 tabsContainer.children[0].click();
            }
        }, 100);


        function loadSemanaContent(semanaData, activeButton) {
            document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
            activeButton.classList.add('active');

            let contentHtml = `<h3 class="text-2xl font-semibold text-indigo-600 mb-4">Semana ${semanaData.semana}: ${semanaData.periodo}</h3>`;
            
            contentHtml += `<div class="mb-6 space-y-3">`;
            semanaData.disciplinas.forEach((disc, idx) => {
                const taskId = `semana${semanaData.semana}-disc${idx}`;
                contentHtml += `
                    <div class="bg-white p-3 rounded-md shadow-sm border border-indigo-100">
                        <input type="checkbox" id="${taskId}" class="custom-checkbox mr-2 sr-only" onchange="toggleTask(this)">
                        <label for="${taskId}" class="text-lg font-medium text-slate-700 cursor-pointer relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:w-4 before:h-4 before:border-2 before:border-gray-400 before:rounded-sm after:font-bold">
                           ${disc.nome}
                        </label>
                        <p class="text-sm text-gray-600 ml-6 mt-1">${disc.topicos}</p>
                    </div>`;
            });
            contentHtml += `</div>`;

            if (semanaData.complementar && semanaData.complementar.length > 0) {
                contentHtml += `<h4 class="text-xl font-semibold text-teal-600 mt-6 mb-2">Disciplinas/Tópicos Complementares:</h4>`;
                contentHtml += `<div class="mb-6 space-y-3">`;
                semanaData.complementar.forEach((comp, idx) => {
                    const taskId = `semana${semanaData.semana}-comp${idx}`;
                    contentHtml += `
                        <div class="bg-white p-3 rounded-md shadow-sm border border-teal-100">
                             <input type="checkbox" id="${taskId}" class="custom-checkbox mr-2 sr-only" onchange="toggleTask(this)">
                             <label for="${taskId}" class="text-lg font-medium text-slate-700 cursor-pointer relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:w-4 before:h-4 before:border-2 before:border-gray-400 before:rounded-sm after:font-bold">
                                ${comp.nome}
                             </label>
                             <p class="text-sm text-gray-600 ml-6 mt-1">${comp.topicos}</p>
                        </div>`;
                });
                contentHtml += `</div>`;
            }

            contentHtml += `<h4 class="text-xl font-semibold text-amber-600 mt-6 mb-2">Atividades da Semana:</h4>`;
            const taskIdAtividades = `semana${semanaData.semana}-atividades`;
            contentHtml += `
                <div class="bg-white p-3 rounded-md shadow-sm border border-amber-100">
                    <input type="checkbox" id="${taskIdAtividades}" class="custom-checkbox mr-2 sr-only" onchange="toggleTask(this)">
                    <label for="${taskIdAtividades}" class="text-lg font-medium text-slate-700 cursor-pointer relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:w-4 before:h-4 before:border-2 before:border-gray-400 before:rounded-sm after:font-bold">
                        ${semanaData.atividades}
                    </label>
                </div>`;

            cronogramaContent.innerHTML = contentHtml;
        }
        
        window.toggleTask = function(checkbox) {
            const label = checkbox.nextElementSibling;
            if (checkbox.checked) {
                label.classList.add('task-completed');
            } else {
                label.classList.remove('task-completed');
            }
        }


        // Edital Accordion
        const editalAccordion = document.getElementById('edital-accordion');
        Object.keys(editalData).forEach((disciplina, index) => {
            const accordionItem = `
                <div>
                    <button type="button" class="flex items-center justify-between w-full p-4 font-medium text-left text-slate-600 bg-indigo-50 border border-indigo-200 rounded-lg hover:bg-indigo-100 focus:ring-2 focus:ring-indigo-300" data-accordion-target="#accordion-body-${index}" aria-expanded="false" aria-controls="accordion-body-${index}">
                        <span><i class="fas fa-book mr-2 text-indigo-500"></i>${disciplina}</span>
                        <svg data-accordion-icon class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div id="accordion-body-${index}" class="hidden p-5 border border-t-0 border-indigo-200 rounded-b-lg bg-white">
                        <ul class="list-disc list-inside space-y-1 text-sm text-gray-600 mb-4">
                            ${editalData[disciplina].map(topico => `<li>${topico}</li>`).join('')}
                        </ul>
                        <button onclick="generateDiscursiveQuestion('${disciplina}')" class="mt-2 px-4 py-2 bg-indigo-600 text-white font-semibold rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-opacity-50">
                            ✨ Gerar Questão Discursiva
                        </button>
                    </div>
                </div>
            `;
            editalAccordion.innerHTML += accordionItem;
        });

        document.querySelectorAll('[data-accordion-target]').forEach(button => {
            button.addEventListener('click', () => {
                const targetId = button.getAttribute('data-accordion-target');
                const targetPanel = document.querySelector(targetId);
                const expanded = button.getAttribute('aria-expanded') === 'true' || false;
                
                button.setAttribute('aria-expanded', !expanded);
                targetPanel.classList.toggle('hidden');
                const icon = button.querySelector('[data-accordion-icon]');
                icon.classList.toggle('rotate-180');
            });
        });
        
        // Legislação Table
        const legislacaoTableBody = document.getElementById('legislacao-table-body');
        legislacaoData.forEach(item => {
            const row = `
                <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">${item.norma}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">${item.data}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">${item.disciplinas}</td>
                    <td class="px-6 py-4 text-sm text-slate-500">${item.relevancia}</td>
                </tr>
            `;
            legislacaoTableBody.innerHTML += row;
        });

        // Smooth scroll for nav links
        document.querySelectorAll('header nav a').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                    const headerOffset = document.querySelector('header').offsetHeight;
                    const elementPosition = targetElement.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - headerOffset - 20; // 20px extra padding

                    window.scrollTo({
                        top: offsetPosition,
                        behavior: "smooth"
                    });
                }
            });
        });

        // Animate sections on scroll
        const sections = document.querySelectorAll('.section-fade-in');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.animationPlayState = 'running';
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        sections.forEach(section => {
            observer.observe(section);
        });

    });
</script>

